name: Container Workflow

on:
  workflow_dispatch

env:
  ACR_LOGIN_SERVER: aistraining.azurecr.io
  TAG_NAME: eshoponweb-phanupong:1.0.0
  IMAGE_NAME: aistraining.azurecr.io/eshoponweb-037:1.0.0

jobs:
  build-container:
    runs-on: ubuntu-latest

steps:
      - name: Checkout source code
        uses: actions/checkout@v4 # แนะนำ v4 หรือ v5 ตามปกติ

      - name: Login to Azure Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.ACR_LOGIN_SERVER }}
          username: ${{ secrets.ACR_USERNAME }}
          password: ${{ secrets.ACR_PASSWORD }}

      - name: Build Docker image
        run: |
          docker build -f src/Web/Dockerfile -t ${{ env.IMAGE_NAME }} .
          docker images
        
      - name: Push Docker image
        run: |
          docker push ${{ env.IMAGE_NAME }}
