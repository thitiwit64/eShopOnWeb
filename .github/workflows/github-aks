name: Container Workflow
on: workflow_dispatch

env:
  ACR_LOGIN_SERVER: aistraining.azurecr.io
  TAG_NAME: eshoponweb-phanupong:1.0.0
  IMAGE_NAME: aistraining.azurecr.io/eshoponwebapp-user003:1.0.0
  RESOURCE_GROUP: ais-training
  CLUSTER_NAME: aks-demo

jobs:
  deploy-to-aks:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout source code
        uses: actions/checkout@v4

      - name: Azure Login
        uses: azure/login@v2
        with:
          creds: ${{ secrets.AZURE_CREDENTIALS }}

      - name: Set AKS Context
        uses: azure/aks-set-context@v3
        with:
          creds: ${{ secrets.AZURE_CREDENTIALS }}
          resource-group: ${{ env.RESOURCE_GROUP }}
          cluster-name: ${{ env.CLUSTER_NAME }}

      - name: Create K8s Secret for ACR
        uses: azure/k8s-create-secret@v4
        with:
          container-registry-url: ${{ env.ACR_LOGIN_SERVER }}
          container-registry-name: aistraining
          container-registry-username: ${{ secrets.ACR_USERNAME }}
          container-registry-password: ${{ secrets.ACR_PASSWORD }}
          secret-name: aks-secret-${{ github.run_id }}

      - name: Deploy to Kubernetes cluster
        uses: azure/k8s-deploy@v5
        with:
          manifests: |
            .k8s/deployment.yaml
            .k8s/service.yaml
          images: ${{ env.IMAGE_NAME }}
          imagepullsecrets: |
            aks-secret-${{ github.run_id }}
